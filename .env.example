# Copia questo file in .env e inserisci le variabili richieste

# API key OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Stringa di connessione PostgreSQL
# Formato: postgresql://user:password@host:port/dbname
# Su Railway si trova in: Settings > Variables > DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/azienda
